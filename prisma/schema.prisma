generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(EMPLOYEE)
  employeeCode String?  @unique
  department   String   @default("General")
  jobTitle     String   @default("Staff")
  branch       String   @default("Main Campus")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attendances       Attendance[] @relation("FacultyAttendance")
  approvedAttendance Attendance[] @relation("ApprovedAttendance")
  leaves            Leave[]
  notices           Notice[]
}

model Attendance {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation("FacultyAttendance", fields: [userId], references: [id], onDelete: Cascade)
  date              DateTime         @default(now())
  checkInAt         DateTime?
  checkOutAt        DateTime?
  status            AttendanceStatus @default(ABSENT)
  lateMinutes       Int              @default(0)
  totalWorkingHours Float?
  breakMinutes      Int?
  branch            String?
  remarks           String?
  batchAssigned     String?
  classesTaken      Int?
  studentsPresent   Int?
  studentsAbsent    Int?
  selfMarked        Boolean          @default(true)
  approvedById      String?
  approvedBy        User?            @relation("ApprovedAttendance", fields: [approvedById], references: [id])
  createdAt         DateTime         @default(now())

  @@unique([userId, date])
}

model Settings {
  id            Int    @id @default(1)
  officeIP      String @default("192.168.10.1")
  shiftStart    String @default("09:00")
  graceMinutes  Int    @default(5)
  latesPerCut   Int    @default(3)
}

model Leave {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  fromDate  String
  toDate    String
  reason    String
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  body      String
  priority  String   @default("Normal")
  createdAt DateTime @default(now())
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

